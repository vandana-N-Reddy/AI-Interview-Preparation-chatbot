# Set default behavior, let Git handle text files automatically
* text=auto

# Force LF for common text file types to avoid cross-platform warnings
*.py text eol=lf
*.txt text eol=lf
*.md text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
.env text eol=lf
